PCO_CLIENT_SECRET=

# Planning Center requires an identifying User-Agent on every API request.
PCO_USER_AGENT=ECC Service Times v2 (communications@emmanuelcc.org)

# Supabase. Keep the service-role key server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
